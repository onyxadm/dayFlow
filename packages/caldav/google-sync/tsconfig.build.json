{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist/build",
    "declaration": true,
    "emitDeclarationOnly": false,
    "declarationDir": "dist/types",
    "declarationMap": false,
    "sourceMap": false,
    "module": "ESNext",
    "target": "ES2017",
    "noEmit": false,
    "rootDir": "src",
    "paths": {
      "@google-sync/*": ["./src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules", "**/*.test.ts", "**/*.spec.ts"]
}
